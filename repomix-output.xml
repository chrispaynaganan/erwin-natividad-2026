.section { padding-top: 72px; padding-bottom: 72px; }
.eyebrow { color: var(--accent-soft); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; }
.headTitle { font-size: clamp(1.9rem, 4vw, 2.5rem); }
.headSub { color: var(--text-muted); margin-top: 10px; max-width: 60ch; }

/* ---------- Hero ---------- */
.hero { padding-top: 56px; padding-bottom: 32px; }
.heroGrid { display: grid; grid-template-columns: 1fr; gap: 40px; align-items: center; }
.heroName { font-size: clamp(3.5rem, 12vw, 7rem); line-height: 0.95; letter-spacing: -0.03em; font-weight: 400; }
.heroNameGold { display: block; color: var(--accent); }
.tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
.heroEyebrow { color: var(--accent-soft); font-weight: 600; margin-top: 28px; font-size: 1.05rem; }
.heroBody { color: var(--text-muted); margin-top: 10px; max-width: 52ch; font-size: 0.98rem; }
.featuredLabel { color: var(--accent-soft); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; margin-top: 26px; }
.featuredTitle { font-weight: 600; margin-top: 2px; margin-bottom: 12px; }
.heroCtas { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 22px; }
.heroPhoto { width: 100%; aspect-ratio: 4 / 5; border-radius: 20px; background: var(--surface-2); border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center; color: var(--text-muted); font-size: 0.85rem; }
@media (min-width: 900px) { .heroGrid { grid-template-columns: 1.1fr 0.9fr; } }

/* ---------- Logo strip ---------- */
.logos { text-align: center; padding-top: 8px; padding-bottom: 8px; }
.logosLabel { color: var(--text-muted); font-size: 0.9rem; }
.logosRow { display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 24px; align-items: center; margin-top: 28px; opacity: 0.5; }
.logoChip { height: 28px; border-radius: 6px; background: var(--surface-2); }

/* ---------- Service cards ---------- */
.cards3 { display: grid; grid-template-columns: 1fr; gap: 24px; margin-top: 36px; }
@media (min-width: 820px) { .cards3 { grid-template-columns: repeat(3, 1fr); } }
.serviceCard { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); display: flex; flex-direction: column; }
.serviceImg { aspect-ratio: 16 / 9; background: var(--surface-2); }
.serviceBody { padding: 20px; display: flex; flex-direction: column; gap: 10px; flex: 1; }
.serviceBody h3 { font-size: 1.3rem; font-weight: 700; }
.serviceBody p { color: var(--text-muted); font-size: 0.9rem; flex: 1; }
.serviceBtns { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 4px; }

/* ---------- Featured work ---------- */
.workHead { display: flex; justify-content: space-between; align-items: flex-end; gap: 16px; flex-wrap: wrap; }
.workGrid { display: grid; grid-template-columns: 1fr; gap: 24px; margin-top: 36px; }
@media (min-width: 760px) { .workGrid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1040px) { .workGrid { grid-template-columns: repeat(3, 1fr); } }
.workCard { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px; display: flex; flex-direction: column; gap: 12px; box-shadow: var(--shadow); }
.workTags { display: flex; flex-wrap: wrap; gap: 6px; }
.workCard h3 { font-size: 1.15rem; font-weight: 700; }
.workCard p { color: var(--text-muted); font-size: 0.88rem; }
.workDate { color: var(--text-muted); font-size: 0.78rem; }

/* ---------- Meet Erwin ---------- */
.meetGrid { display: grid; grid-template-columns: 1fr; gap: 40px; align-items: center; }
@media (min-width: 900px) { .meetGrid { grid-template-columns: 1fr 1fr; } }
.meetPhoto { width: 100%; aspect-ratio: 1 / 1; border-radius: var(--radius); background: var(--surface-2); border: 1px solid var(--border); }
.meetQuote { font-weight: 700; font-size: 1.05rem; margin: 14px 0 18px; }
.meetBody { color: var(--text-muted); font-size: 0.95rem; display: grid; gap: 14px; margin-bottom: 22px; }

