        <Reveal>
          <h2 className={s.headTitle}>{about.skills.title} <span className="gold">{about.skills.titleGold}</span></h2>
          <p className={s.headSub}>{about.skills.sub}</p>
        </Reveal>
        <div className={s.skillsGrid}>
          {about.skills.groups.map((c, i) => (
