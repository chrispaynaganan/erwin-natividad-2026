  border: 1px solid var(--border); border-radius: 12px; padding: 12px 16px; background: var(--surface); }
.capLabel { font-size: 0.72rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); }
.capValue { font-size: 1.05rem; display: inline-flex; align-items: center; gap: 6px; }
.capValue strong { font-size: 1.3rem; color: var(--accent); }
.capFull { color: #C0392B !important; }
.capHint { font-size: 0.72rem; color: var(--text-muted); }
.capEditBtn { display: inline-flex; align-items: center; justify-content: center; width: 24px; height: 24px;
  border-radius: 6px; border: 1px solid var(--border); background: var(--surface-2); color: var(--text-muted); cursor: pointer; }
.capEditBtn:hover { color: var(--text); }
.capEditRow { display: inline-flex; align-items: center; gap: 6px; }
.capInput { width: 64px; padding: 4px 8px; border-radius: 8px; border: 1px solid var(--border);
  background: var(--bg); color: var(--text); font: inherit; font-size: 0.9rem; }
.capSave, .capCancel { padding: 4px 10px; border-radius: 8px; font: inherit; font-size: 0.8rem; cursor: pointer; }
.capSave { border: none; background: var(--accent); color: var(--btn-fg); }
.capCancel { border: 1px solid var(--border); background: transparent; color: var(--text-muted); }

/* Feedback */
.ok, .err { display: inline-flex; align-items: center; gap: 6px; font-size: 0.85rem; margin-bottom: 12px; }
.ok { color: #2E7D32; }
.err { color: #C0392B; }

/* Toolbar */
.toolbar { display: grid; gap: 12px; margin-bottom: 18px; }
.tabs { display: flex; flex-wrap: wrap; gap: 6px; border-bottom: 1px solid var(--border); padding-bottom: 12px; }
.tab { padding: 7px 14px; border-radius: var(--radius-sm); border: 1px solid transparent; background: transparent;
  color: var(--text-muted); font: inherit; font-size: 0.875rem; cursor: pointer; transition: background 0.15s ease, color 0.15s ease; }
.tab:hover { background: var(--surface-2); color: var(--text); }
