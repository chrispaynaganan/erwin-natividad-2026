const blankTier = (): PricingTier => ({ name: 'New package', badge: '', featured: false, pricePrefix: 'From', discountPercent: 0, useCustomPrice: false, customPriceLabel: 'Let\u2019s Talk', desc: '', listLabel: 'Includes:', list: [], cta: 'Book' })

